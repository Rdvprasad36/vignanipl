rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read own doc or if admin; write own doc
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Games: anyone authenticated can read; admin can write
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Questions: read by authenticated users; write by admin only
    match /questions/{qId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Players: read by authenticated users; write by admin only
    match /players/{pId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
